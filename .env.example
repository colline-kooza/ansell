# Application
APP_ENV=production
PORT=8080

# PostgreSQL container init
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ansell_db

# Database — user/password must match POSTGRES_USER/POSTGRES_PASSWORD above
DATABASE_URL=host=ansell-postgres user=postgres password=postgres dbname=ansell_db port=5432 sslmode=disable TimeZone=UTC

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-please-change-in-production-32chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://ansell-api.collinzdev.com/api/auth/google/callback

# Frontend
FRONTEND_URL=https://ansell.collinzdev.com

# API URL — no /v1 suffix, routes live under /api
NEXT_PUBLIC_API_BASE_URL=https://ansell-api.collinzdev.com/api

# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY_ID=cd742474f47fea66b42efd4212964702
CLOUDFLARE_R2_SECRET_ACCESS_KEY=fb5ee4a628dd7987684751a0cbd7b3e939149d2402b9688498fad78fa4087c47
CLOUDFLARE_R2_ENDPOINT=https://f4e23784fe15f407c091677c2f00e430.r2.cloudflarestorage.com
