# ─── Copy this to .env and fill in every value before deploying ──────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ansell
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=ansell_db

# Full DSN — must match the POSTGRES_* values above
DATABASE_URL=host=ansell-postgres user=ansell password=CHANGE_ME_strong_password dbname=ansell_db port=5432 sslmode=disable TimeZone=UTC

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=8080

# Minimum 32 random bytes — generate with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.anasell.com/api/v1/auth/google/callback

# ─── Public URLs ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://anasell.com

# ─── Next.js (baked into JS bundle at build time — rebuild web on change) ────
NEXT_PUBLIC_API_BASE_URL=https://api.anasell.com/api/v1

# ─── Cloudflare R2 Storage ───────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=ansell-assets
CLOUDFLARE_R2_PUBLIC_URL=https://ansell-assets.codelabs.pro
