# ─── Copy this entire block into Coolify's environment variable section ───────
# Fill in every value — nothing here has a safe default for production.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Only needed if you're running the postgres container from docker-compose.prod.yml.
# If you use a hosted DB, you can leave these blank — only DATABASE_URL matters.
POSTGRES_USER=ansell
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=ansell_db

# ─── Database connection (Go API) ─────────────────────────────────────────────
# Replace the values with your hosted DB credentials.
# For most providers (Supabase, Neon, Railway, etc.) use sslmode=require.
# Example for Supabase: host=db.xxxx.supabase.co user=postgres password=YOUR_PASS dbname=postgres port=5432 sslmode=require TimeZone=UTC
# Example for Neon:     host=ep-xxx.us-east-1.aws.neon.tech user=YOUR_USER password=YOUR_PASS dbname=YOUR_DB port=5432 sslmode=require TimeZone=UTC
DATABASE_URL=host=YOUR_DB_HOST user=YOUR_DB_USER password=YOUR_DB_PASSWORD dbname=YOUR_DB_NAME port=5432 sslmode=require TimeZone=UTC

# ─── API server ───────────────────────────────────────────────────────────────
APP_ENV=production
API_PORT=8080
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.anasell.com/api/auth/google/callback

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://anasell.com

# Full base URL the browser uses to reach the API — baked into the JS bundle at build time.
# Must match the /api route prefix of the Go server (no /v1 suffix).
NEXT_PUBLIC_API_BASE_URL=https://api.anasell.com/api

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=cd742474f47fea66b42efd4212964702
CLOUDFLARE_R2_SECRET_ACCESS_KEY=fb5ee4a628dd7987684751a0cbd7b3e939149d2402b9688498fad78fa4087c47
